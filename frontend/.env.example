# Get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API URL.
# Leave unset (or set to /api) for local dev — Vite proxies /api → localhost:8000.
# In production set to your Render backend URL, e.g.:
# VITE_API_URL=https://reviewpulse-api.onrender.com
VITE_API_URL=
