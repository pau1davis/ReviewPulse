# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Found in: Supabase dashboard → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Found in: Supabase dashboard → Project Settings → Database → Connection string (URI)
# Use the "Session mode" URI (port 5432), not transaction mode
DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379/0
# Production: your Redis provider URL
REDIS_URL=redis://localhost:6379/0

# ── LLM Providers ─────────────────────────────────────────────────────────────
# Groq: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Which provider to use: "groq" or "gemini"
LLM_PROVIDER=groq

# Which model to use per provider
# Groq options:   llama-3.3-70b-versatile, mixtral-8x7b-32768
# Gemini options: gemini-2.0-flash, gemini-1.5-pro
LLM_MODEL=llama-3.3-70b-versatile

# ── App Security ──────────────────────────────────────────────────────────────
# Used to sign HMAC webhook payloads — generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-random-hex-secret-here

# ── Celery ────────────────────────────────────────────────────────────────────
# Usually the same as REDIS_URL; kept separate so you can use different DBs
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
